# Copy this to .env for local development.
# DO NOT commit .env — it's in .gitignore.

# Fine-grained PAT with read access to your public + private repos.
# Without this, the build can only fetch public events (which is fine for
# local dev as long as you accept that the sparkline will be public-only).
# In production this is set in Render's environment variables.
GITHUB_TOKEN=
