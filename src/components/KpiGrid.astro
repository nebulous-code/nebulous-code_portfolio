---
/**
 * KpiGrid — arranges KpiCells with hairline dividers.
 *
 * The 1px-gap-on-line-background pattern: each cell paints its own
 * background, the grid paints `line` underneath, so the gaps between
 * cells render as 1px hairline dividers without needing actual border
 * styles on individual cells.
 *
 * Usage:
 *   <KpiGrid columns={4}>
 *     <KpiCell label="last push" tone="orange">2d ago</KpiCell>
 *     <KpiCell label="latest release">—</KpiCell>
 *     <KpiCell label="commits 30d">47</KpiCell>
 *     <KpiCell label="open prs">—</KpiCell>
 *   </KpiGrid>
 */

interface Props {
  columns?: number;
  class?: string;
}

const { columns = 4, class: className = '' } = Astro.props;
---

<div
  class:list={['kpi-grid', className]}
  style={`grid-template-columns: repeat(${columns}, minmax(0, 1fr));`}
>
  <slot />
</div>

<style>
  .kpi-grid {
    display: grid;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
</style>
