---
/**
 * Prose — wrapper that applies running-prose styles to its children.
 *
 * Use around long-form body content (case study MDX, about/resume copy,
 * etc.). Styles are namespaced under .prose and declared global because
 * MDX-rendered children come from a different scope than the wrapper
 * and won't pick up Astro's scoped class hashes otherwise.
 *
 * Per DESIGN_DOC §3:
 *   - Body in Recursive Mono Casual (MONO 1, CASL 1, wght 400).
 *   - Italics use the slant axis (slnt -8), not font-style: italic.
 *   - Inline <code> uses Departure Mono so it visibly differs from
 *     the surrounding mono body.
 *   - Headings inside prose use Source Serif 4.
 *
 * Usage:
 *   <Prose><Content /></Prose>
 *   <Prose><p>Static paragraph.</p></Prose>
 */

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['prose', className]}>
  <slot />
</div>

<style is:global>
  .prose {
    font-family: var(--font-body);
    font-variation-settings: "MONO" 1, "CASL" 1, "wght" 400;
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 640px;
  }

  /* Paragraphs */
  .prose p {
    margin-block: var(--space-6);
  }

  .prose p:first-child {
    margin-top: 0;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  /* Bold — Recursive uses wght axis. */
  .prose strong,
  .prose b {
    font-variation-settings: "MONO" 1, "CASL" 1, "wght" 500;
    font-weight: 500;
    color: var(--color-ink);
  }

  /* Italic — Recursive uses the slnt axis, not font-style. */
  .prose em,
  .prose i {
    font-variation-settings: "MONO" 1, "CASL" 1, "wght" 400, "slnt" -8;
    font-style: normal;
  }

  /* Headings */
  .prose h2,
  .prose h3,
  .prose h4 {
    font-family: var(--font-serif);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .prose h2 {
    font-size: 26px;
    line-height: 1.2;
    margin-top: var(--space-10);
    margin-bottom: var(--space-5);
  }

  .prose h3 {
    font-size: 19px;
    line-height: 1.25;
    margin-top: var(--space-9);
    margin-bottom: var(--space-4);
  }

  .prose h4 {
    font-size: 16px;
    line-height: 1.3;
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
  }

  /* Inline code — Departure Mono so it pops against Recursive prose. */
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-blue);
  }

  /* Code blocks */
  .prose pre {
    background: var(--color-bg-inset);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    overflow-x: auto;
    margin-block: var(--space-7);
    font-size: 13px;
    line-height: 1.5;
  }

  .prose pre code {
    font-family: var(--font-mono);
    font-size: inherit;
    color: var(--color-ink);
    background: transparent;
    padding: 0;
  }

  /* Blockquotes */
  .prose blockquote {
    border-left: 2px solid var(--color-blue);
    padding-inline-start: var(--space-6);
    margin-inline: 0;
    margin-block: var(--space-7);
    color: var(--color-ink-muted);
  }

  .prose blockquote p {
    margin-block: var(--space-3);
  }

  /* Lists */
  .prose ul,
  .prose ol {
    margin-block: var(--space-6);
    padding-inline-start: var(--space-9);
  }

  .prose li {
    margin-block: var(--space-3);
  }

  .prose ul li::marker {
    color: var(--color-ink-faint);
  }

  .prose ol li::marker {
    color: var(--color-ink-faint);
  }

  /* Links — inherit global color, underline on hover. */
  .prose a {
    color: var(--color-blue);
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  /* Horizontal rules — subtle divider. */
  .prose hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin-block: var(--space-10);
  }
</style>
