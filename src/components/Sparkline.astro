---
interface Point {
  date: string;
  count: number;
}

interface Props {
  points: Point[];
  width?: number;
  height?: number;
  unit?: string;
  ariaLabel?: string;
}

const {
  points,
  width = 80,
  height = 16,
  unit = 'count',
  ariaLabel = 'recent count',
} = Astro.props;

// (math unchanged from before)
const PAD = 2;
const innerW = Math.max(0, width - PAD * 2);
const innerH = Math.max(0, height - PAD * 2);

const max = Math.max(1, ...points.map((p) => p.count));
const stepX = points.length > 1 ? innerW / (points.length - 1) : 0;

const coords = points.map((p, i) => {
  const x = PAD + i * stepX;
  const y = PAD + innerH - (p.count / max) * innerH;
  return { x, y };
});

const polylinePoints = coords.map((c) => `${c.x},${c.y}`).join(' ');
const last = coords[coords.length - 1];
const lastPoint = points[points.length - 1];

// Aggregate info for the polyline tooltip
const total = points.reduce((sum, p) => sum + p.count, 0);
const days = points.length;
---

<svg
  class="sparkline"
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  role="img"
  aria-label={ariaLabel}
  preserveAspectRatio="none"
>
  {points.length > 0 && (
    <>
      <polyline
        points={polylinePoints}
        fill="none"
        stroke="var(--color-green)"
        stroke-width="1"
        stroke-linejoin="round"
        stroke-linecap="round"
        vector-effect="non-scaling-stroke"
      />
      {last && (
        <circle
          cx={last.x}
          cy={last.y}
          r="2"
          fill="var(--color-green)"
        />
      )}
      {/* Invisible hover-catcher covering the entire sparkline. Showing
          the latest value is the most useful signal regardless of where
          the cursor lands. */}
      <rect
        x="0"
        y="0"
        width={width}
        height={height}
        fill="transparent"
        pointer-events="all"
      >
        {lastPoint && (
          <title>{`${lastPoint.count} ${unit} on ${lastPoint.date}`}</title>
        )}
      </rect>
    </>
  )}
</svg>

<style>
  .sparkline {
    display: block;
  }
</style>
