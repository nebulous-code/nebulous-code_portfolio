---
/**
 * Dynamic case study route.
 *
 * For each MDX file in src/content/projects/, this generates a static page
 * at /projects/[slug]. The page combines the MDX body (the writeup) with
 * project metadata from src/config/projects.ts (live demo URL, repo URL,
 * visibility-based affordances).
 *
 * The slug field in the MDX frontmatter MUST match a slug in PROJECTS for
 * the secondary links to render correctly.
 */

import BaseLayout from '~/layouts/BaseLayout.astro';
import Prose from '~/components/Prose.astro';
import { getCollection, render } from 'astro:content';
import { getProjectBySlug } from '~/config/projects';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const project = getProjectBySlug(entry.data.slug);

const publishedLabel = entry.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});

const codeUrl = project ? `https://github.com/${project.repo}` : null;
---

<BaseLayout title={`${entry.data.title} — nebulous-code`} description={entry.data.summary}>
  <div class="container-narrow">
    <article>
      <header class="case-header">
        <p class="meta">{publishedLabel}</p>
        <h1 class="display">{entry.data.title}</h1>
        <p class="lede">{entry.data.summary}</p>

        {project ? (
          <div class="actions">
            {project.liveDemoUrl ? (
              <a class="action-link" href={project.liveDemoUrl} target="_blank" rel="noopener">
                live demo →
              </a>
            ) : null}
            {project.visibility === 'public' && codeUrl ? (
              <a class="action-link" href={codeUrl} target="_blank" rel="noopener">
                code →
              </a>
            ) : null}
            {project.visibility === 'private-saas' && project.productUrl ? (
              <a class="action-link" href={project.productUrl} target="_blank" rel="noopener">
                visit product →
              </a>
            ) : null}
          </div>
        ) : null}
      </header>

      <hr class="divider" />

      <div class="body">
        <Prose>
          <Content />
        </Prose>
      </div>

      <hr class="divider" />

      <footer class="case-footer">
        {project ? (
          <div class="actions">
            {project.liveDemoUrl ? (
              <a class="action-link" href={project.liveDemoUrl} target="_blank" rel="noopener">
                live demo →
              </a>
            ) : null}
            {project.visibility === 'public' && codeUrl ? (
              <a class="action-link" href={codeUrl} target="_blank" rel="noopener">
                code →
              </a>
            ) : null}
            {project.visibility === 'private-saas' && project.productUrl ? (
              <a class="action-link" href={project.productUrl} target="_blank" rel="noopener">
                visit product →
              </a>
            ) : null}
          </div>
        ) : null}
        <a class="back-link" href="/projects">← all projects</a>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .case-header {
    padding-block: var(--space-9) var(--space-10);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-ink-faint);
    margin: 0 0 var(--space-6) 0;
  }

  .display {
    font-family: var(--font-serif);
    font-size: 44px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-6) 0;
    color: var(--color-ink);
  }

  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-7) 0;
    max-width: 640px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-7);
    align-items: center;
  }

  .action-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-blue);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .action-link:hover {
    text-decoration: underline;
  }

  .divider {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin: 0;
  }

  .body {
    padding-block: var(--space-10);
  }

  .case-footer {
    padding-block: var(--space-9);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-7);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .back-link:hover {
    color: var(--color-ink);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .display {
      font-size: 32px;
    }
    .lede {
      font-size: 16px;
    }
  }
</style>
