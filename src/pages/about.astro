---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Prose from '~/components/Prose.astro';
---

<BaseLayout title="About — nebulous-code">
  <div class="container-narrow">
    <header class="page-header">
      <p class="eyebrow">ABOUT</p>
      <h1 class="display">About</h1>
      <p class="lede">
        I'm Nicholas — a software developer with about a decade of experience
        across web development, scrum/product work, and senior engineering
        roles.
      </p>
    </header>

    <hr class="divider" />

    <div class="body">
      <Prose>
        <p>
          I currently work at a home inspection company building reporting
          tools, internal developer tooling, and full-stack web applications.
        </p>

        <p>
          My happy place is the seam between "build the thing" and "understand
          what the thing should do." That's why I'm drawn to reporting and
          analytics work — it sits exactly there. Outside of my day job I run
          a small publishing company, write fiction, and build tools for
          hobbies I refuse to take seriously (the Pokémon TCG dashboard,
          Rubik's cube practice apps, emulators).
        </p>

        <p>
          <em>TODO: expand this in slice 5.</em>
        </p>
      </Prose>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-block: var(--space-9) var(--space-10);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-ink-faint);
    margin: 0 0 var(--space-6) 0;
  }

  .display {
    font-family: var(--font-serif);
    font-size: 44px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-6) 0;
    color: var(--color-ink);
  }

  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 640px;
  }

  .divider {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin: 0;
  }

  .body {
    padding-block: var(--space-10);
  }

  @media (max-width: 640px) {
    .display {
      font-size: 32px;
    }
    .lede {
      font-size: 16px;
    }
  }
</style>
