---
/**
 * Home page.
 *
 * The "developer is a verb" dashboard. Three live signals here:
 *   1. Currently-building text (from src/content/now.md, hand-curated)
 *   2. Activity sparkline (from getCommitActivity, baked at build time)
 *   3. Project cards with last-update labels (from getProjectActivity)
 *
 * All GitHub data is fetched during the build via src/lib/github.ts, which
 * applies the deny-by-default sanitization rules. By the time this page is
 * rendered to static HTML, no API calls remain.
 */

import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import PushChart from '~/components/PushChart.astro';
import { getFeaturedProjects } from '~/config/projects';
import { getCommitActivity, getProjectActivity } from '~/lib/github';

import Button from '~/components/Button.astro';
import Sparkline from '~/components/Sparkline.astro';

const GITHUB_USERNAME = 'nebulous-code';

// Build-time data fetch. Each function is fault-tolerant — a failed fetch
// returns an empty/degraded result rather than crashing the build.
const [activity, projectActivity] = await Promise.all([
  getCommitActivity(GITHUB_USERNAME, 90),
  getProjectActivity(),
]);

const featured = getFeaturedProjects();
const activityByRepo = new Map(projectActivity.map((p) => [p.repo, p]));
---

<BaseLayout title="nebulous-code">
  <div style="display: flex; gap: 1rem; align-items: center;">
  <Sparkline
    points={[
      { date: '2026-04-01', count: 2 },
      { date: '2026-04-02', count: 5 },
      { date: '2026-04-03', count: 1 },
      { date: '2026-04-04', count: 8 },
      { date: '2026-04-05', count: 3 },
      { date: '2026-04-06', count: 7 },
      { date: '2026-04-07', count: 4 },
    ]}
    unit="commits"
  />
  <Sparkline
    points={[
      { date: '2026-04-01', count: 2 },
      { date: '2026-04-02', count: 5 },
      { date: '2026-04-03', count: 1 },
      { date: '2026-04-04', count: 8 },
      { date: '2026-04-05', count: 3 },
      { date: '2026-04-06', count: 7 },
      { date: '2026-04-07', count: 4 },
    ]}
  />
  <Sparkline
    points={Array.from({ length: 7 }, (_, i) => ({
      date: `2026-04-0${i + 1}`,
      count: 0,
    }))}
  />
  <Sparkline
    points={[{ date: '2026-04-01', count: 5 }]}
  />
</div>
  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
    <Button variant="primary">primary</Button>
    <Button variant="secondary">secondary</Button>
    <Button variant="ghost">ghost</Button>
    <Button variant="highlight">highlight</Button>
    <Button href="/about">link as button</Button>
    <Button href="https://github.com" target="_blank">external link</Button>
  </div>
  <section class="mb-16">
    <h1 class="mb-3 text-4xl font-bold">Nicholas</h1>
    <p class="text-lg" style="color: var(--color-text-dim)">
      Full-stack developer with a decade of experience and a soft spot for reporting,
      data pipelines, and tools that make other developers faster.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider" style="color: var(--color-text-dim)">
      Recent Activity
    </h2>
    <PushChart points={activity} />
  </section>

  <section class="mb-16">
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider" style="color: var(--color-text-dim)">
      Currently Building
    </h2>
    {/*
      TODO slice 5: read this from src/content/now.md properly via a content
      collection. For slice 1 we just hardcode a placeholder so the page renders.
    */}
    <p>
      Working on the <strong>Pokémon Card Market Intelligence Dashboard</strong> —
      recently shipped a Magikarp-themed dark UI and price distribution charts.
      Also drilling OLL algorithms in <strong>Cube Practice</strong> and
      sketching out a Game Boy emulator as the next deep dive.
    </p>
  </section>

  <section>
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider" style="color: var(--color-text-dim)">
      Projects
    </h2>
    <div class="grid gap-4">
      {
        featured.map((project) => (
          <ProjectCard project={project} activity={activityByRepo.get(project.repo)} />
        ))
      }
    </div>
  </section>
</BaseLayout>
