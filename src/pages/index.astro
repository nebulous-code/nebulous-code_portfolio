---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Logo from '~/components/Logo.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import PushChart from '~/components/PushChart.astro';
import Button from '~/components/Button.astro';
import { getFeaturedProjects } from '~/config/projects';
import { getCommitActivity, getProjectActivity } from '~/lib/github';
import fs from 'node:fs/promises';
import path from 'node:path';

const GITHUB_USERNAME = 'nebulous-code';

// Build-time data fetch.
const [activity, projectActivity] = await Promise.all([
  getCommitActivity(GITHUB_USERNAME, 90),
  getProjectActivity(),
]);

// Read the "currently building" hand-edited content.
const nowPath = path.resolve('./src/content/now.md');
const nowRaw = await fs.readFile(nowPath, 'utf-8');
// Strip the YAML frontmatter and trim. Simple split — no parser needed.
const nowBody = nowRaw.replace(/^---[\s\S]*?---\s*/, '').trim();

const featured = getFeaturedProjects();
const activityByRepo = new Map(projectActivity.map((p) => [p.repo, p]));
---

<BaseLayout title="nebulous-code">
  <div class="container-wide">
    <section class="hero">
      <Logo size={72} ariaLabel="nebulous-code" class="hero-logo" />
      <h1 class="display">Nicholas Licalsi </h1>
      <p class="lede">
        Full-stack developer with a decade of experience and a soft spot for
        reporting, data pipelines, and the tools that make other developers
        faster.
      </p>
      <div class="hero-actions">
        <Button href="/projects">see projects →</Button>
        <Button variant="ghost" href="/about">about me</Button>
      </div>
    </section>

    <section class="section">
      <Eyebrow>recent activity</Eyebrow>
      <div class="section-body">
        <PushChart points={activity} unit="commits" />
      </div>
    </section>

    <section class="section">
      <Eyebrow>currently building</Eyebrow>
      <div class="section-body">
        <p class="now-text" set:html={nowBody.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}></p>
      </div>
    </section>

    <section class="section">
      <Eyebrow>projects</Eyebrow>
      <div class="section-body project-grid">
        {featured.map((project) => (
          <ProjectCard project={project} activity={activityByRepo.get(project.repo)} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ───── Hero ───── */
  .hero {
    padding-block: var(--space-9) var(--space-11);
  }

  .hero :global(.hero-logo) {
    margin-bottom: var(--space-7);
  }

  .display {
    font-family: var(--font-serif);
    font-size: 48px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-7) 0;
    color: var(--color-ink);
  }

  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-9) 0;
    max-width: 640px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-5);
    align-items: center;
  }

  /* ───── Section pattern ───── */
  .section {
    padding-block: var(--space-9);
    border-top: 1px solid var(--color-line);
  }

  .section-body {
    margin-top: var(--space-7);
  }

  /* ───── Currently Building ───── */
  .now-text {
    font-family: var(--font-body);
    font-variation-settings: "MONO" 1, "CASL" 1, "wght" 400;
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0;
    max-width: 640px;
  }

  .now-text :global(strong) {
    font-variation-settings: "MONO" 1, "CASL" 1, "wght" 500;
    color: var(--color-ink);
  }

  /* ───── Project grid ───── */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 800px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ───── Mobile ───── */
  @media (max-width: 640px) {
    .display {
      font-size: 36px;
    }
    .lede {
      font-size: 16px;
    }
    .hero-actions {
      flex-wrap: wrap;
    }
  }
</style>
